# Garagetwits — environment variable template
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
#
# EXPO_PUBLIC_* variables are bundled into the client build and are safe
# to expose only for values that are intentionally public (anon key, project URL).
# Do NOT add server-only secrets under EXPO_PUBLIC_.

# ── Supabase (client-safe) ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Supabase Dashboard → Settings → API → anon/public key
# This key is intentionally public — it is subject to Row Level Security.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase CLI (never expose client-side) ───────────────────────────────────
# Found in: https://supabase.com/dashboard/account/tokens
# Used only for: supabase db push / supabase link
# Set in your shell profile or CI secrets — do NOT put in .env (Expo would bundle it)
# SUPABASE_ACCESS_TOKEN=your-supabase-management-token
